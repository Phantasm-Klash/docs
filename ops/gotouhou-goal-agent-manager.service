[Unit]
Description=Supervise gotouhou sustained goal agents

[Service]
Type=oneshot
WorkingDirectory=/root/gotouhou/docs
Environment=HOME=/root
Environment=XDG_CONFIG_HOME=/root/.config
Environment=GH_CONFIG_DIR=/root/.config/gh
Environment=GOCACHE=/root/.cache/go-build
Environment=GOPATH=/root/go
TimeoutStartSec=20min
ExecStart=/bin/sh /root/gotouhou/docs/ops/goal_agent_supervisor_runner.sh
